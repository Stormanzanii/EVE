<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <!--
      Style Selector="ScrollBar" with a Template setter kept losing to
      FluentTheme's own ScrollBar ControlTheme (which the ScrollViewer's
      internal ScrollBar picks up via its Theme, not via type-selector
      matching, so a plain Style never actually won). Registering our own
      ControlTheme under the SAME implicit key FluentTheme uses
      ({x:Type ScrollBar}) replaces it outright instead of trying to out-
      specificity it - this is the supported way to fully re-skin a Fluent
      control. No track box, no up/down buttons - just the draggable thumb.
    -->
    <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="MinHeight" Value="10" />
      <Setter Property="Template">
        <ControlTemplate>
          <Track Name="PART_Track"
                 Minimum="{TemplateBinding Minimum}"
                 Maximum="{TemplateBinding Maximum}"
                 Value="{TemplateBinding Value, Mode=TwoWay}"
                 ViewportSize="{TemplateBinding ViewportSize}"
                 Orientation="{TemplateBinding Orientation}"
                 IsDirectionReversed="True">
            <Track.Thumb>
              <Thumb Name="thumb" Classes="scrollThumb" />
            </Track.Thumb>
          </Track>
        </ControlTemplate>
      </Setter>
      <Style Selector="^:vertical">
        <Setter Property="Width" Value="10" />
      </Style>
      <Style Selector="^:horizontal">
        <Setter Property="Height" Value="10" />
      </Style>
    </ControlTheme>
  </Styles.Resources>
  <!--
    Shared control styles for the whole app. These must live at Application
    level (referenced from App.axaml), not inside MainWindow.axaml's own
    Window.Styles - a Window's local Styles only apply within that window's
    own visual tree, not to separately-created dialog Windows (the update
    dialog and the CS2 capture notice dialog were both silently falling
    back to bare FluentTheme defaults because of this before this file
    existed, which is why they looked visually inconsistent with the rest
    of the app.
  -->
  <!--
    Thumb's own default Fluent template ignores plain Background/CornerRadius
    Setters on the instance (its internal Border binds fixed theme resources,
    not TemplateBinding), which is why the corner radius and color kept
    getting lost - overriding Thumb's Template directly, scoped to this class
    only, is the only way to actually control its appearance. Color matches
    EVE's own dark background family rather than standing out - it's meant to
    be a subtle scroll indicator, not a UI accent.
  -->
  <Style Selector="ScrollViewer.settingsScroll ScrollBar:vertical">
    <Setter Property="Margin" Value="0,6,5,6" />
  </Style>
  <Style Selector="Thumb.scrollThumb">
    <Setter Property="Background" Value="#1E2A35" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="5" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Thumb.scrollThumb:pointerover">
    <Setter Property="Background" Value="#283744" />
  </Style>
  <Style Selector="Thumb.scrollThumb:pressed">
    <Setter Property="Background" Value="#324255" />
  </Style>

  <!-- Volume mute toggle (per-track lanes AND the master volume controls) -
       a plain Border (not Button) so it never inherits Fluent's press-scale
       animation, which made it visibly shrink/jump on click. Always shows a
       visible background/border box (not just on hover) so it reads as a
       clickable button on sight - a plain icon with no box, only reacting on
       hover, gave no visual hint it was interactive at all. -->
  <Style Selector="Border.muteToggle">
    <Setter Property="Background" Value="#1B242D" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.1" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.1" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.muteToggle:pointerover">
    <Setter Property="Background" Value="#26323E" />
    <Setter Property="BorderBrush" Value="#3E5064" />
  </Style>

  <Style Selector="Button.deleteButton">
    <Setter Property="Background" Value="#D85E61" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="20,10" />
  </Style>
  <Style Selector="Button:not(ToggleSwitch)">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#D8E4F2" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button:not(ToggleSwitch):pointerover">
    <Setter Property="Background" Value="#263544" />
  </Style>
  <Style Selector="Button:not(ToggleSwitch):disabled">
    <Setter Property="Opacity" Value="0.48" />
  </Style>
  <Style Selector="Button.transportButton">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="#24313C" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="15" />
  </Style>
  <Style Selector="Button.playButton">
    <Setter Property="Width" Value="38" />
    <Setter Property="Height" Value="38" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#2B3642" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button.primaryButton">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <!--
    Selector="Button.primaryButton:pointerover" alone kept losing to the
    generic "Button:not(ToggleSwitch):pointerover" rule above it (every
    primaryButton - Export, Import Selected, Check Now, etc. - showed that
    grey hover instead of the accent color). Matching the same :not(ToggleSwitch)
    shape as the generic rule (plus the extra class) makes this an
    unambiguous superset that reliably wins.
  -->
  <Style Selector="Button.primaryButton:not(ToggleSwitch):pointerover">
    <Setter Property="Background" Value="{StaticResource AccentBrushHover}" />
  </Style>
  <!--
    Both rules above still lost for Export specifically. Root cause: Fluent's
    own Button ControlTemplate has its OWN internal pointerover visual state
    painting a template part from a theme resource, not from the Button's
    Background property via TemplateBinding - no external Style setting
    Background, at ANY specificity, can out-compete a template painting
    something that was never wired to Background in the first place. Giving
    the button its own minimal template (Border+ContentPresenter, Background
    via TemplateBinding) removes Fluent's template from the equation
    entirely, so the plain :pointerover Background setter below actually has
    something to reach. Same fix applied to Check Now and Update Now, which
    hit the identical issue.
  -->
  <Style Selector="Button#ExportButton, Button#CheckNowButton, Button#UpdateNowButton">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                             Padding="{TemplateBinding Padding}"
                             Foreground="{TemplateBinding Foreground}"
                             FontSize="{TemplateBinding FontSize}"
                             FontWeight="{TemplateBinding FontWeight}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button#ExportButton:pointerover, Button#CheckNowButton:pointerover, Button#UpdateNowButton:pointerover">
    <Setter Property="Background" Value="{StaticResource AccentBrushHover}" />
  </Style>
  <Style Selector="Button.deleteButton:pointerover">
    <Setter Property="Background" Value="#E16B6D" />
  </Style>
  <Style Selector="Button.closeEditor">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#D8E4F2" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="12,8" />
  </Style>
  <!--
    linkButton/brandButton/gameFilterBadge all used Padding="0" +
    Background="Transparent" on :pointerover, meaning "no visible hover pill
    at all" was the intent - but Fluent's own Button ControlTemplate paints
    its OWN internal pointerover highlight from a theme resource, never wired
    to the Button's Background property (same root cause already diagnosed
    and fixed for Export/Check Now/Update Now above), so a small, badly-sized
    highlight showed regardless of what these styles set. Giving each its own
    minimal Border+ContentPresenter template removes Fluent's template from
    the equation, so a real, content-sized hover pill can be painted instead.
  -->
  <Style Selector="Button.linkButton">
    <!-- Not Colors.Transparent (#00FFFFFF - white at zero alpha) - a
         BrushTransition from that to an opaque dark color interpolates the
         RGB channels through white along the way, which reads as a visible
         white flash on hover-enter/exit. Same RGB as the hover color below,
         just zero alpha, so only alpha animates. -->
    <Setter Property="Background" Value="#001D2A36" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Foreground" Value="#BDD4EE" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                             Padding="{TemplateBinding Padding}"
                             Foreground="{TemplateBinding Foreground}"
                             FontSize="{TemplateBinding FontSize}"
                             FontWeight="{TemplateBinding FontWeight}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.linkButton:pointerover">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="Button.linkButton:pointerover PathIcon">
    <Setter Property="Foreground" Value="#D2DEEC" />
  </Style>
  <Style Selector="Button.brandButton">
    <Setter Property="Background" Value="#001D2A36" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                             Padding="{TemplateBinding Padding}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.brandButton:pointerover">
    <Setter Property="Background" Value="#1D2A36" />
  </Style>
  <Style Selector="Button.gameFilterBadge">
    <Setter Property="Background" Value="#001D2A36" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                             Padding="{TemplateBinding Padding}"
                             HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                             VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.gameFilterBadge:pointerover">
    <Setter Property="Background" Value="#1D2A36" />
  </Style>
  <Style Selector="Button.gameFilterBadge:pointerover TextBlock">
    <Setter Property="Foreground" Value="#D2DEEC" />
  </Style>
  <Style Selector="Button.gameFilterBadge:pointerover PathIcon">
    <Setter Property="Foreground" Value="#D2DEEC" />
  </Style>
  <!-- Per-card date-header "select whole day" checkbox - hidden (zero width,
       transparent, non-hit-testable) until hovering the date row itself,
       then slides open. The date TextBlock is a later sibling in the same
       horizontal StackPanel, so it gets pushed right by ordinary layout
       flow as the checkbox's Width transitions from 0 - no RenderTransform
       needed. First position-animated hover effect in this codebase (every
       other Transitions usage here only animates Background color). -->
  <Style Selector="CheckBox.dayCheck">
    <!-- Collapsed default state lives here as Style setters, not as local
         XAML attributes on the element - a local attribute value always
         wins over a Style setter for the same property regardless of
         selector specificity, which would permanently block the
         :pointerover rule below from ever taking effect. -->
    <Setter Property="Width" Value="0" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Width" Duration="0:0:0.15" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.clipDateRow:pointerover CheckBox.dayCheck">
    <!-- Wider than the checkbox glyph itself looks like it needs - Fluent's
         default CheckBox template reserves its own internal padding/margin
         around the glyph regardless of Width, so a tight Width here clips
         the checkbox against the text sitting right next to it. -->
    <Setter Property="Width" Value="26" />
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
  </Style>
  <!-- Stays revealed once checked, independent of hover - unchecking it
       (still requires hovering back over the row first, since it's hidden
       again once unchecked and the mouse has moved away) reverts to the
       hover-only reveal above. -->
  <Style Selector="CheckBox.dayCheck:checked">
    <Setter Property="Width" Value="26" />
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
  </Style>
  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Background" Value="#141D24" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="MinWidth" Value="180" />
  </Style>
  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="#141D24" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="MinWidth" Value="180" />
  </Style>
  <!-- Plain Flyout (not MenuFlyout) uses its own FlyoutPresenter and falls
       back to Fluent's default light-themed chrome unless styled to match -
       used by the Game Filters / Clip Type Filters checklist dropdowns. -->
  <Style Selector="FlyoutPresenter">
    <Setter Property="Background" Value="#141D24" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="MinWidth" Value="200" />
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#B8C7D8" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="13,9" />
  </Style>
  <Style Selector="MenuItem:pointerover">
    <Setter Property="Background" Value="#263544" />
    <Setter Property="Foreground" Value="#D8E4F2" />
  </Style>
  <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#263544" />
  </Style>
  <Style Selector="Button.replayButton">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#9FB0C3" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style Selector="Button.replayButton.recording">
    <Setter Property="Background" Value="#3A1E24" />
    <Setter Property="Foreground" Value="#FF8A8F" />
    <Setter Property="BorderBrush" Value="#D85E61" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.replayButton.recording:pointerover">
    <Setter Property="Background" Value="#472228" />
  </Style>
  <Style Selector="Button.dialogClose">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Foreground" Value="#8EA1B6" />
  </Style>
  <Style Selector="Button.dialogClose:pointerover">
    <Setter Property="Background" Value="#D85E61" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="ComboBox.settingsInput, TextBox.settingsInput">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#D8E4F2" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="MinHeight" Value="42" />
  </Style>
  <Style Selector="Border.settingsCard">
    <Setter Property="Background" Value="#141D24" />
    <Setter Property="BorderBrush" Value="#232F3A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="18" />
  </Style>
  <Style Selector="ComboBox.settingsInput /template/ Border#PopupBorder">
    <Setter Property="Background" Value="#141D24" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="6" />
  </Style>
  <Style Selector="ComboBox.settingsInput ComboBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#B8C7D8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="ComboBox.settingsInput ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#263544" />
    <Setter Property="Foreground" Value="#D8E4F2" />
  </Style>
  <Style Selector="ComboBox.settingsInput ComboBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="ListBox.pillGroup">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <WrapPanel Orientation="Horizontal" />
      </ItemsPanelTemplate>
    </Setter>
  </Style>
  <Style Selector="ListBox.pillGroup ListBoxItem">
    <Setter Property="Background" Value="#1D2A36" />
    <Setter Property="Foreground" Value="#B8C7D8" />
    <Setter Property="BorderBrush" Value="#2C3B48" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Margin" Value="0,0,8,8" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.pillGroup ListBoxItem:pointerover">
    <Setter Property="Background" Value="#263544" />
  </Style>
  <Style Selector="ListBox.pillGroup ListBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="ListBox.pillGroup ListBoxItem:selected:pointerover">
    <Setter Property="Background" Value="{StaticResource AccentBrushHover}" />
  </Style>
  <Style Selector="Button.autoClipCardHeader">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.autoClipCardHeader:pointerover">
    <Setter Property="Background" Value="#182029" />
  </Style>
  <!-- "All Kills" sub-header - previously fully transparent at rest (only
       colored on hover, same as the outer CS2 card header), which read as
       plain floating text rather than an actual control. Gets its own
       resting background so it looks like a distinct nested row. Combined
       class selector (not a separate Button.allKillsHeader rule) so it
       reliably wins over the plain autoClipCardHeader rule above for the
       same Background property. -->
  <Style Selector="Button.autoClipCardHeader.allKillsHeader">
    <Setter Property="Background" Value="#161F28" />
    <Setter Property="Padding" Value="12,10" />
  </Style>
  <Style Selector="Button.autoClipCardHeader.allKillsHeader:pointerover">
    <Setter Property="Background" Value="#1C2733" />
  </Style>
  <Style Selector="Button.settingsNavButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#93A6B8" />
    <Setter Property="BorderThickness" Value="2,0,0,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="0,7,7,0" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="Margin" Value="0,0,0,2" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.1" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.settingsNavButton TextBlock">
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="Button.settingsNavButton:pointerover">
    <Setter Property="Background" Value="#182029" />
    <Setter Property="Foreground" Value="#D8E4F2" />
  </Style>
  <Style Selector="Button.settingsNavButton.active">
    <Setter Property="Background" Value="#1B2A3D" />
    <Setter Property="Foreground" Value="#EDF4FB" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.settingsNavButton.active:pointerover">
    <Setter Property="Background" Value="#1B2A3D" />
  </Style>
  <!-- Shared by every volume slider - per-track lanes AND both master
       volume controls (regular editor + fullscreen) - so all three look and
       feel identical. Perfectly round (Width=Height, CornerRadius=half),
       not the taller pill shape this used before. -->
  <Style Selector="Slider.volumeSlider /template/ Thumb">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="#EEF4FF" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="Transitions">
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Slider.volumeSlider /template/ Thumb:pointerover">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrushHover}" />
    <Setter Property="RenderTransform" Value="scale(1.15)" />
  </Style>
  <Style Selector="Slider.volumeSlider /template/ Thumb:pressed">
    <Setter Property="Background" Value="#EAF0FF" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="RenderTransform" Value="scale(1.05)" />
  </Style>
</Styles>
