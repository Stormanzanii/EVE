<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Eve.App.ViewModels"
        x:Class="Eve.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EVE"
        Width="1180"
        Height="780"
        MinWidth="920"
        MinHeight="620"
        Background="#0D1116">
  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#171F27" BorderBrush="#1E2A33" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="24" Height="24" CornerRadius="5" Background="#13C8B5" />
          <TextBlock Text="EVE" FontSize="18" FontWeight="Bold" Foreground="#EDF4FB" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="18,0,0,0" VerticalAlignment="Center">
          <Button Content="{Binding RecorderStatus}" Classes="replayButton" />
          <Button Content="Clip" IsEnabled="{Binding IsReplayRecording}" />
          <TextBlock Text="Ctrl+Shift+F9" Foreground="#93A6B8" FontWeight="Bold" VerticalAlignment="Center" />
          <Border Width="1" Height="20" Background="#2A3640" />
          <TextBlock Text="{Binding ActiveGame}" Foreground="#BDD4EE" VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="320,*">
      <Border Background="#10171D" BorderBrush="#1F2B34" BorderThickness="0,0,1,0">
        <DockPanel Margin="20">
          <TextBlock DockPanel.Dock="Top" Text="Clips" Foreground="#C4D9F2" FontSize="14" FontWeight="Bold" />
          <ListBox ItemsSource="{Binding Clips}" Margin="0,18,0,0" Background="Transparent" />
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="*,220">
        <Border Background="#0E141A">
          <TextBlock Text="Native preview/editor surface"
                     Foreground="#9AAABB"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
        <Border Grid.Row="1" Background="#141D24" BorderBrush="#22303A" BorderThickness="0,1,0,0">
          <TextBlock Text="Timeline and replay controls will move here as capture backends are implemented."
                     Foreground="#9AAABB"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
