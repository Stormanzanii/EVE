<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Eve.App.ViewModels"
        x:Class="Eve.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EVE"
        Width="1180"
        Height="780"
        MinWidth="920"
        MinHeight="620"
        Background="#0D1116"
        Icon="/Assets/eve-icon.ico">
  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#171F27" BorderBrush="#1E2A33" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Image Source="/Assets/eve-icon-24.png" Width="24" Height="24" />
          <TextBlock Text="EVE" FontSize="18" FontWeight="Bold" Foreground="#EDF4FB" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="18,0,0,0" VerticalAlignment="Center">
          <Button Content="{Binding RecorderStatus}" Classes="replayButton" />
          <Button Content="Clip" IsEnabled="{Binding IsReplayRecording}" />
          <TextBlock Text="Ctrl+Shift+F9" Foreground="#93A6B8" FontWeight="Bold" VerticalAlignment="Center" />
          <Border Width="1" Height="20" Background="#2A3640" />
          <TextBlock Text="{Binding ActiveGame}" Foreground="#BDD4EE" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="Folder" Click="FolderButton_OnClick" />
          <Button Content="Open" Click="OpenButton_OnClick" />
          <Button Content="Refresh" Click="RefreshButton_OnClick" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#101820" IsVisible="{Binding IsLibraryVisible}">
      <DockPanel Margin="20,18">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="{Binding LibraryHeaderDate}" Foreground="#C4D0DF" FontSize="15" FontWeight="Bold" />
            <TextBlock Text="{Binding LibraryHeaderGame}" Foreground="#647181" FontSize="15" FontWeight="Bold" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding LibraryFolderDisplay}" Foreground="#647181" FontSize="12" VerticalAlignment="Center" />
        </Grid>

        <ListBox ItemsSource="{Binding Clips}"
                 Margin="-4,14,-4,0"
                 Padding="0"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Width="368"
                      Margin="4,4,14,26"
                      Background="#24303A"
                      CornerRadius="4"
                      ClipToBounds="True">
                <Grid RowDefinitions="207,118">
                  <Border Background="#16202A">
                    <Grid>
                      <Border Background="#1A2630">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="#6F7D8B"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="26"
                                   TextAlignment="Center" />
                      </Border>

                      <Border HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,12,12,0"
                              Padding="10,6"
                              Background="#1A2530"
                              CornerRadius="18">
                        <TextBlock Text="{Binding DurationLabel}" Foreground="#D8E2EE" FontSize="14" FontWeight="Bold" />
                      </Border>

                      <Border HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,12,12"
                              Width="34"
                              Height="34"
                              Background="#253341"
                              CornerRadius="17">
                        <TextBlock Text="*" Foreground="#C7D3E1" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </Grid>
                  </Border>

                  <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="16,14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding GameLabel}"
                                 Foreground="#8C98A7"
                                 FontSize="13"
                                 FontWeight="Bold" />
                      <TextBlock Text="{Binding Name}"
                                 Foreground="#D2DEEC"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 TextTrimming="CharacterEllipsis" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="TIME" Foreground="#8C98A7" FontSize="12" FontWeight="Bold" />
                        <TextBlock Text="{Binding DateLabel}"
                                   Foreground="#8C98A7"
                                   FontSize="12"
                                   FontWeight="Bold" />
                      </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                      <Button Content="Share" Width="58" Height="44" FontSize="12" />
                      <Button Content="..." Width="48" Height="44" FontSize="16" />
                    </StackPanel>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="*,220" IsVisible="{Binding IsEditorVisible}">
      <Border Background="#0E141A">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="{Binding SelectedVideoName}"
                     Foreground="#EDF4FB"
                     FontSize="18"
                     FontWeight="Bold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding SelectedVideoPath}"
                     Foreground="#93A6B8"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
      <Border Grid.Row="1" Background="#141D24" BorderBrush="#22303A" BorderThickness="0,1,0,0">
        <TextBlock Text="Timeline"
                   Foreground="#9AAABB"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
    </Grid>
  </Grid>
</Window>
