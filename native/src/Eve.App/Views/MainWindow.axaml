<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:vm="using:Eve.App.ViewModels"
        xmlns:controls="using:Eve.App.Controls"
        x:Class="Eve.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EVE"
        Width="1180"
        Height="780"
        MinWidth="920"
        MinHeight="620"
        Background="#0D1116"
        Icon="/Assets/eve-icon.ico"
        SizeChanged="Window_OnSizeChanged">
  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#171F27" BorderBrush="#1E2A33" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0" VerticalAlignment="Center">
        <Button Classes="brandButton" Click="OpenSettingsButton_OnClick">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Image Source="/Assets/eve-icon-24.png" Width="24" Height="24" />
            <TextBlock Text="EVE" FontSize="18" FontWeight="Bold" Foreground="#EDF4FB" />
          </StackPanel>
        </Button>

        <Grid Grid.Column="1"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,1*,Auto,3*"
              Margin="18,0,0,0"
              VerticalAlignment="Center">
          <Button Grid.Column="0" Content="{Binding RecorderStatus}" Classes="replayButton" Classes.recording="{Binding IsReplayRecording}" Click="ReplayButton_OnClick" />
          <Button Grid.Column="1" Content="Clip" IsEnabled="{Binding IsReplayRecording}" Click="ClipButton_OnClick" Margin="10,0,0,0" />
          <TextBlock Grid.Column="2" Text="{Binding HotkeyDisplay}" Foreground="#93A6B8" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0" />
          <Border Grid.Column="3" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding ShowLibraryStatus}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="4" Text="{Binding ActiveGame}" Foreground="#BDD4EE" VerticalAlignment="Center" IsVisible="{Binding ShowLibraryStatus}" Margin="10,0,0,0" />
          <Border Grid.Column="5" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding HasSelection}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="6"
                     Text="{Binding SelectionSummary}"
                     Foreground="#D7E2EF"
                     FontSize="14"
                     FontWeight="Bold"
                     VerticalAlignment="Center"
                     IsVisible="{Binding HasSelection}"
                     Margin="10,0,0,0" />
          <Button Grid.Column="7"
                  Content="Delete"
                  Classes="deleteButton"
                  Click="DeleteSelectedButton_OnClick"
                  IsVisible="{Binding HasSelection}"
                  Margin="10,0,0,0" />
          <Border Grid.Column="8" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="9" Text="{Binding SelectedCreated}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <Border Grid.Column="10" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="11" Text="{Binding SelectedQuality}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" TextTrimming="CharacterEllipsis" MaxWidth="180" Margin="10,0,0,0" />
          <Border Grid.Column="12" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="13" Text="{Binding SelectedSize}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" TextTrimming="CharacterEllipsis" MaxWidth="110" Margin="10,0,0,0" />
          <Border Grid.Column="14" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding HasSelectedCaptureBackend}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="15"
                     Text="{Binding SelectedCaptureBackend}"
                     Foreground="#93A6B8"
                     VerticalAlignment="Center"
                     IsVisible="{Binding HasSelectedCaptureBackend}"
                     TextTrimming="CharacterEllipsis"
                     Margin="10,0,0,0" />
          <Border Grid.Column="16" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <Button Grid.Column="17" Classes="linkButton" Click="EditorPathButton_OnClick" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0">
            <TextBlock Text="{Binding SelectedVideoPath}" TextTrimming="CharacterEllipsis" />
          </Button>
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsVisible="{Binding ShowLibraryActions}">
          <Button Content="Folder" Click="FolderButton_OnClick" />
          <Button Content="Open" Click="OpenButton_OnClick" />
          <Button Content="Refresh" Click="RefreshButton_OnClick" />
        </StackPanel>
        <Button Grid.Column="2"
                Content="X"
                Classes="closeEditor"
                Click="CloseEditorButton_OnClick"
                IsVisible="{Binding IsEditorVisible}" />
        <Button Grid.Column="2"
                Content="Back"
                Classes="closeEditor"
                Click="CloseSettingsButton_OnClick"
                IsVisible="{Binding ShowSettingsClose}" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#101820" IsVisible="{Binding IsLibraryVisible}">
      <DockPanel Margin="20,18">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
          <TextBlock Text="{Binding LibraryTitle}"
                     Foreground="#C4D0DF"
                     FontSize="15"
                     FontWeight="Bold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Classes="linkButton"
                  Click="LibraryPathButton_OnClick"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding LibraryLocationText}"
                       Foreground="#647181"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
          </Button>

        </Grid>

        <ScrollViewer Margin="-4,14,-4,0">
          <ItemsControl ItemsSource="{Binding ClipGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,24">
                  <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,0,0,12">
                    <CheckBox IsChecked="{Binding IsSelected}" Click="GroupCheckBox_OnClick" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Label}"
                               Foreground="#B8C7D8"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                  </StackPanel>

                  <ItemsControl ItemsSource="{Binding Clips}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding $parent[Window].DataContext.CardWidth}"
                                Margin="4,4,20,24"
                                Background="#24303A"
                                CornerRadius="12"
                                BoxShadow="0 6 18 -6 #66000000"
                                PointerPressed="ClipCard_OnPointerPressed"
                                PointerEntered="ClipCard_OnPointerEntered"
                                PointerExited="ClipCard_OnPointerExited">
                          <Border CornerRadius="12" ClipToBounds="True">
                          <Grid RowDefinitions="Auto,104">
                            <Border Grid.RowSpan="2"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    IsVisible="{Binding IsSelected}"
                                    IsHitTestVisible="False"
                                    ZIndex="10" />
                            <Border Background="#16202A" Height="{Binding $parent[Window].DataContext.CardImageHeight}">
                              <Grid>
                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,12,12,0"
                                        Padding="10,6"
                                        Background="#1A2530"
                                        CornerRadius="18">
                                  <TextBlock Text="{Binding DurationLabel}" Foreground="#D8E2EE" FontSize="14" FontWeight="Bold" />
                                </Border>
                                <CheckBox HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Margin="14"
                                          IsChecked="{Binding IsSelected}"
                                          IsVisible="{Binding IsCheckVisible}"
                                          Click="ClipCheckBox_OnClick" />
                              </Grid>
                            </Border>

                            <StackPanel Grid.Row="1" Spacing="7" Margin="16,14,16,10">
                              <TextBlock Text="{Binding Name}"
                                         Foreground="#D2DEEC"
                                         FontSize="15"
                                         FontWeight="Bold"
                                         TextTrimming="CharacterEllipsis" />
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="TIME" Foreground="#8C98A7" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="{Binding DateLabel}"
                                           Foreground="#8C98A7"
                                           FontSize="12"
                                           FontWeight="Bold" />
                              </StackPanel>
                              <TextBlock Text="{Binding CaptureBackendLabel}"
                                         Foreground="#6B7C8C"
                                         FontSize="11"
                                         IsVisible="{Binding HasCaptureBackendLabel}"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                          </Grid>
                          </Border>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Background="#101820" IsVisible="{Binding IsSettingsVisible}">
      <ScrollViewer>
        <StackPanel Margin="32,28" Spacing="22" MaxWidth="860">
          <TextBlock Text="Settings" Foreground="#EDF4FB" FontSize="26" FontWeight="Bold" />

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Replay Buffer" Foreground="#C4D0DF" FontWeight="Bold" />
              <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="16">
                <TextBlock Text="Save hotkey" Foreground="#93A6B8" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="{Binding HotkeyDisplay}" Click="HotkeyCaptureButton_OnClick" HorizontalAlignment="Left" MinWidth="180" />
                <TextBlock Grid.Row="1" Text="Replay length" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding ReplayDurationPresets}" SelectedItem="{Binding SelectedReplayDurationPreset}" Width="160" HorizontalAlignment="Left" />
                <TextBlock Grid.Row="2" Text="Replay quality" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Row="2" Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding ReplayQualityPresets}" SelectedItem="{Binding SelectedReplayQualityPreset}" Width="240" HorizontalAlignment="Left" />
                <TextBlock Grid.Row="3" Text="Capture backend" Foreground="#93A6B8" VerticalAlignment="Center" />
                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="6">
                  <ComboBox Classes="settingsInput" ItemsSource="{Binding ReplayBackends}" SelectedItem="{Binding SelectedReplayBackend}" Width="320" HorizontalAlignment="Left" />
                  <TextBlock Text="{Binding SelectedReplayBackend.Description}" Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Left" />
                  <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding ReplayBackendRestartRequired}">
                    <TextBlock Text="Restart EVE for the backend change to take effect." Foreground="#E5A00D" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="Restart Now" Click="RestartAppButton_OnClick" />
                  </StackPanel>
                </StackPanel>
                <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Start replay buffer when EVE opens" IsChecked="{Binding StartReplayOnLaunch}" />
                <CheckBox Grid.Row="5" Grid.ColumnSpan="2" Content="Force SDR" IsChecked="{Binding ForceSdrDuringReplay}">
                  <ToolTip.Tip>
                    <TextBlock Text="Tonemaps HDR footage down to SDR when saving a clip, so it looks like it was captured without HDR instead of washed-out or blown-out. Your display stays in HDR the whole time - only the saved clip changes." TextWrapping="Wrap" MaxWidth="360" />
                  </ToolTip.Tip>
                </CheckBox>
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Clip Notifications" Foreground="#C4D0DF" FontWeight="Bold" />
              <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" RowSpacing="12" ColumnSpacing="16">
                <TextBlock Text="Overlay position" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding ClipOverlayPositions}" SelectedItem="{Binding SelectedClipOverlayPosition}" Width="160" HorizontalAlignment="Left" />
                <TextBlock Grid.Row="1" Text="Sound volume" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding ClipOverlayVolumes}" SelectedItem="{Binding SelectedClipOverlayVolume}" Width="160" HorizontalAlignment="Left" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Startup" Foreground="#C4D0DF" FontWeight="Bold" />
              <CheckBox Content="Launch EVE on Windows boot" IsChecked="{Binding LaunchOnWindowsStartup}" />
              <CheckBox Content="Start minimized on boot" IsChecked="{Binding StartMinimizedToTray}" />
            </StackPanel>
          </Border>

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Audio" Foreground="#C4D0DF" FontWeight="Bold" />
              <Grid ColumnDefinitions="220,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12" ColumnSpacing="16">
                <TextBlock Text="Chat Audio App" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedChatProcess}" MaxWidth="520" />
                <Button Grid.Column="2" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                <TextBlock Grid.Row="1" Text="Microphone" Foreground="#93A6B8" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="1" Classes="settingsInput" ItemsSource="{Binding MicrophoneDevices}" SelectedItem="{Binding SelectedMicrophoneDevice}" MaxWidth="520" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Game Audio Exclusions" Foreground="#C4D0DF" FontWeight="Bold" />
              <TextBlock Text="Apps here are removed from Game Audio. Chat Audio captures the selected app above." Foreground="#718296" />
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedProcessExclusion}" />
                <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                <Button Grid.Column="2" Content="Add" Click="AddSelectedProcessButton_OnClick" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBox Name="ExcludedProcessTextBox" Classes="settingsInput" Watermark="discord.exe" />
                <Button Grid.Column="1" Content="Add Manual" Click="AddExcludedProcessButton_OnClick" />
              </Grid>
              <ItemsControl ItemsSource="{Binding ExcludedProcesses}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                      <TextBlock Text="{Binding}" Foreground="#D8E4F2" VerticalAlignment="Center" />
                      <Button Grid.Column="1" Content="Remove" Click="RemoveExcludedProcessButton_OnClick" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Background="#141D24" BorderBrush="#25323D" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="Diagnostics" Foreground="#C4D0DF" FontWeight="Bold" />
              <Button Content="Open Logs" Click="OpenLogsButton_OnClick" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="*,320" IsVisible="{Binding IsEditorVisible}">
      <Grid Background="#0E141A" ColumnDefinitions="*,300">
        <Border Background="#05080B">
          <vlc:VideoView x:Name="EditorVideoView" />
        </Border>
        <Border Grid.Column="1" Background="#101820" BorderBrush="#1F2B34" BorderThickness="1,0,0,0">
          <StackPanel Margin="20" Spacing="14">
            <TextBlock Text="CLIP DETAILS" Foreground="#C4D9F2" FontSize="13" FontWeight="Bold" />
            <TextBlock Text="Title" Foreground="#93A6B8" FontSize="12" />
            <TextBox Text="{Binding EditorTitle}" Foreground="#EDF4FB" FontSize="14" FontWeight="Bold" Background="#0D151C" BorderBrush="#17232D" />
            <TextBlock Text="Description" Foreground="#93A6B8" FontSize="12" />
            <TextBox Text="{Binding EditorDescription}"
                     MinHeight="86"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Watermark="Type description here"
                     Background="#0D151C"
                     BorderBrush="#17232D"
                     Foreground="#D6E2F0" />
            <Border Height="1" Background="#22303A" Margin="0,10,0,0" />
            <TextBlock Text="Export codec" Foreground="#93A6B8" FontSize="12" />
            <ComboBox Classes="settingsInput"
                      ItemsSource="{Binding ExportCodecs}"
                      SelectedItem="{Binding SelectedExportCodec}"
                      Width="180"
                      HorizontalAlignment="Left" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Background="#141D24" BorderBrush="#22303A" BorderThickness="0,1,0,0">
        <Grid RowDefinitions="44,*" Margin="8,0,8,8">
          <Grid ColumnDefinitions="160,*,Auto" Height="44">
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
              <Button Classes="transportButton" Click="RestartButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 5,3 L 7,3 L 7,17 L 5,17 Z M 17,4 L 17,16 L 8,10 Z" />
              </Button>
              <Button Classes="transportButton" Click="StepBackButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 15,4 L 15,16 L 6,10 Z" />
              </Button>
              <Button Classes="playButton" Click="PlayPauseButton_OnClick">
                <Grid>
                  <PathIcon Width="16" Height="16" Foreground="#DDE8F6" Data="M 7,4 L 17,10 L 7,16 Z" IsVisible="{Binding !IsPlaying}" />
                  <PathIcon Width="16" Height="16" Foreground="#DDE8F6" Data="M 6,4 L 9,4 L 9,16 L 6,16 Z M 12,4 L 15,4 L 15,16 L 12,16 Z" IsVisible="{Binding IsPlaying}" />
                </Grid>
              </Button>
              <Button Classes="transportButton" Click="StepForwardButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 5,4 L 14,10 L 5,16 Z" />
              </Button>
              <Button Classes="transportButton" Click="EndButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 15,3 L 17,3 L 17,17 L 15,17 Z M 4,4 L 13,10 L 4,16 Z" />
              </Button>
            </StackPanel>
            <Button Grid.Column="2"
                    Content="{Binding ExportButtonText}"
                    Classes="primaryButton"
                    Width="150"
                    Height="34"
                    IsEnabled="{Binding !IsExporting}"
                    Click="ExportButton_OnClick" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="160,*" ColumnSpacing="12">
            <Grid RowDefinitions="24,*">
              <TextBlock Text="{Binding TimelineStatusLabel}"
                         Foreground="#A8CFFF"
                         FontSize="11"
                         VerticalAlignment="Bottom"
                         FontFamily="Consolas" />
              <ItemsControl Grid.Row="1" ItemsSource="{Binding TimelineTracks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Height="{Binding LaneHeight}"
                            Margin="0,0,0,6"
                            Background="#2A3540"
                            CornerRadius="4"
                            ClipToBounds="False">
                      <Grid Margin="8,5" RowDefinitions="Auto,36" ColumnDefinitions="18,*,18">
                        <TextBlock Grid.ColumnSpan="3"
                                   Text="{Binding Label}"
                                   Foreground="#D4E0EA"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <PathIcon Grid.Row="1"
                                  Width="14"
                                  Height="14"
                                  Foreground="#D1DEE9"
                                  VerticalAlignment="Center"
                                  Data="M 3,8 L 6,8 L 11,4 L 11,16 L 6,12 L 3,12 Z"
                                  IsVisible="{Binding IsAudio}" />
                        <Slider Grid.Row="1"
                                Grid.Column="1"
                                Classes="volumeSlider"
                                Minimum="0"
                                Maximum="150"
                                Height="34"
                                MinHeight="34"
                                Margin="0,-8,0,0"
                                Value="{Binding VolumePercent, Mode=TwoWay}"
                                IsEnabled="{Binding CanAdjustVolume}"
                                IsVisible="{Binding IsAudio}"
                                PointerPressed="TrackVolume_OnPointerPressed"
                                PointerMoved="TrackVolume_OnPointerMoved"
                                PointerReleased="TrackVolume_OnPointerReleased"
                                PropertyChanged="TrackVolume_OnPropertyChanged" />
                        <PathIcon Grid.Row="1"
                                  Grid.Column="2"
                                  Width="14"
                                  Height="14"
                                  Foreground="#D1DEE9"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 3,8 L 6,8 L 11,4 L 11,16 L 6,12 L 3,12 Z M 13,7 C 15,9 15,11 13,13 M 15,5 C 18,8 18,12 15,15"
                                  IsVisible="{Binding IsAudio}" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#E8EEF8"
                                CornerRadius="4"
                                Padding="5,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{Binding VolumeBadgeMargin}"
                                ZIndex="10"
                                IsHitTestVisible="False"
                                IsVisible="{Binding ShowVolumePercent}">
                          <TextBlock Text="{Binding VolumeLabel}" Foreground="#18202A" FontSize="10" FontWeight="Bold" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="24,*">
              <controls:TimelineRulerControl x:Name="TimelineRuler"
                                             Duration="{Binding Duration}"
                                             PointerPressed="TimelineSurface_OnPointerPressed"
                                             PointerMoved="TimelineSurface_OnPointerMoved"
                                             PointerReleased="TimelineSurface_OnPointerReleased" />
              <Grid x:Name="TimelineSurface"
                    Grid.Row="1"
                    SizeChanged="TimelineSurface_OnSizeChanged"
                    PointerPressed="TimelineSurface_OnPointerPressed"
                    PointerMoved="TimelineSurface_OnPointerMoved"
                    PointerReleased="TimelineSurface_OnPointerReleased">
                <ItemsControl ItemsSource="{Binding TimelineTracks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:TimelineLaneControl Height="{Binding LaneHeight}"
                                                    Margin="0,0,0,6"
                                                    LaneBrush="{Binding Color}"
                                                    IsVideo="{Binding IsVideo}"
                                                    Peaks="{Binding WaveformPeaks}"
                                                    TrimStartPercent="{Binding $parent[Window].DataContext.TrimStartPercentValue}"
                                                    TrimEndPercent="{Binding $parent[Window].DataContext.TrimEndPercentValue}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Canvas x:Name="TimelineOverlay" IsHitTestVisible="False">
                  <Border x:Name="TrimSelection"
                          Height="32"
                          BorderBrush="#13C8B5"
                          BorderThickness="2"
                          CornerRadius="4"
                          Background="#151F24" />
                  <Border x:Name="TimelinePlayhead"
                          Width="3"
                          Background="#F2F6FB" />
                  <Polygon x:Name="PlayheadCap"
                           Points="0,0 16,0 8,10"
                           Fill="#F2F6FB" />
                </Canvas>

                <Canvas x:Name="TimelineHandleLayer">
                  <Border x:Name="TrimStartHandle"
                          Width="14"
                          Height="32"
                          Background="#13C8B5"
                          CornerRadius="2"
                          Cursor="SizeWestEast"
                          PointerPressed="TrimStartHandle_OnPointerPressed"
                          PointerMoved="TimelineSurface_OnPointerMoved"
                          PointerReleased="TimelineSurface_OnPointerReleased" />
                  <Border x:Name="TrimEndHandle"
                          Width="14"
                          Height="32"
                          Background="#13C8B5"
                          CornerRadius="2"
                          Cursor="SizeWestEast"
                          PointerPressed="TrimEndHandle_OnPointerPressed"
                          PointerMoved="TimelineSurface_OnPointerMoved"
                          PointerReleased="TimelineSurface_OnPointerReleased" />
                </Canvas>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>

