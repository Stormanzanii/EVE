<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:vm="using:Eve.App.ViewModels"
        xmlns:controls="using:Eve.App.Controls"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:opconv="using:Eve.App.Converters"
        x:Class="Eve.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EVE"
        Width="1180"
        Height="780"
        MinWidth="920"
        MinHeight="620"
        Background="#0D1116"
        Icon="/Assets/eve-icon.ico"
        SizeChanged="Window_OnSizeChanged">
  <Grid RowDefinitions="48,*">
    <Border Grid.Row="0" Background="#171F27" BorderBrush="#1E2A33" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0" VerticalAlignment="Center">
        <Button Classes="brandButton" Click="LibraryHomeButton_OnClick" ToolTip.Tip="Library">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Image Source="/Assets/eve-icon-24.png" Width="24" Height="24" />
            <TextBlock Text="EVE" FontSize="18" FontWeight="Bold" Foreground="#EDF4FB" />
          </StackPanel>
        </Button>

        <Grid Grid.Column="1"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,1*,Auto,3*"
              Margin="18,0,0,0"
              VerticalAlignment="Center">
          <Button Grid.Column="0" Content="{Binding RecorderStatus}" Classes="replayButton" Classes.recording="{Binding IsReplayRecording}" Click="ReplayButton_OnClick" />
          <Button Grid.Column="1" Content="Clip" IsEnabled="{Binding IsReplayRecording}" Click="ClipButton_OnClick" Margin="10,0,0,0" />
          <TextBlock Grid.Column="2" Text="{Binding HotkeyDisplay}" Foreground="#93A6B8" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0" />
          <Border Grid.Column="3" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding ShowLibraryStatus}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="4" Text="{Binding ActiveGame}" Foreground="#BDD4EE" VerticalAlignment="Center" IsVisible="{Binding ShowLibraryStatus}" Margin="10,0,0,0" />
          <Border Grid.Column="5" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding HasSelection}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="6"
                     Text="{Binding SelectionSummary}"
                     Foreground="#D7E2EF"
                     FontSize="14"
                     FontWeight="Bold"
                     VerticalAlignment="Center"
                     IsVisible="{Binding HasSelection}"
                     Margin="10,0,0,0" />
          <Button Grid.Column="7"
                  Content="Delete"
                  Classes="deleteButton"
                  Click="DeleteSelectedButton_OnClick"
                  IsVisible="{Binding HasSelection}"
                  Margin="10,0,0,0" />
          <Border Grid.Column="8" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="9" Text="{Binding SelectedCreated}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <Border Grid.Column="10" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="11" Text="{Binding SelectedQuality}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" TextTrimming="CharacterEllipsis" MaxWidth="180" Margin="10,0,0,0" />
          <Border Grid.Column="12" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="13" Text="{Binding SelectedSize}" Foreground="#93A6B8" VerticalAlignment="Center" IsVisible="{Binding IsEditorVisible}" TextTrimming="CharacterEllipsis" MaxWidth="110" Margin="10,0,0,0" />
          <Border Grid.Column="14" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding HasSelectedCaptureBackend}" Margin="10,0,0,0" />
          <TextBlock Grid.Column="15"
                     Text="{Binding SelectedCaptureBackend}"
                     Foreground="#93A6B8"
                     VerticalAlignment="Center"
                     IsVisible="{Binding HasSelectedCaptureBackend}"
                     TextTrimming="CharacterEllipsis"
                     Margin="10,0,0,0" />
          <Border Grid.Column="16" Width="1" Height="20" Background="#2A3640" IsVisible="{Binding HasSelectedCaptureBackend}" Margin="10,0,0,0" />
          <Button Grid.Column="17" Classes="linkButton" Click="EditorPathButton_OnClick" IsVisible="{Binding IsEditorVisible}" Margin="10,0,0,0">
            <TextBlock Text="{Binding SelectedVideoPath}" TextTrimming="CharacterEllipsis" />
          </Button>
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsVisible="{Binding ShowLibraryActions}">
          <Border Background="#1A2530" CornerRadius="16" Padding="10,6" IsVisible="{Binding IsGameFilterActive}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding ActiveGameFilterLabel}" Foreground="#D2DEEC" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
              <Button Classes="linkButton" Content="X" Click="ClearGameFilterButton_OnClick" Foreground="#8C98A7" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <Button Click="OpenSettingsButton_OnClick" ToolTip.Tip="Settings">
            <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                      Width="16" Height="16" />
          </Button>
          <Button Content="Folder" Click="FolderButton_OnClick" />
          <Button Content="Refresh" Click="RefreshButton_OnClick" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsEditorVisible}">
          <Button Classes="transportButton" Click="FullscreenButton_OnClick" ToolTip.Tip="Fullscreen">
            <PathIcon Width="14" Height="14" Foreground="#C8D6E6" Data="M7,14H5v5h5v-2H7V14z M5,10h2V7h3V5H5V10z M17,17h-3v2h5v-5h-2V17z M14,5v2h3v3h2V5H14z" />
          </Button>
          <Button Content="X" Classes="closeEditor" Click="CloseEditorButton_OnClick" />
        </StackPanel>
        <Button Grid.Column="2"
                Content="Back"
                Classes="closeEditor"
                Click="CloseSettingsButton_OnClick"
                IsVisible="{Binding ShowSettingsClose}" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#101820" IsVisible="{Binding IsLibraryVisible}">
      <Grid Margin="20,18">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding LibraryTitle}"
                       Foreground="#C4D0DF"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="linkButton"
                    Click="LibraryPathButton_OnClick"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding LibraryLocationText}"
                         Foreground="#647181"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
            </Button>

          </Grid>

          <ScrollViewer Margin="-4,14,-4,0">
            <ItemsControl ItemsSource="{Binding ClipGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,24" IsVisible="{Binding HasVisibleClips}">
                  <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,0,0,12">
                    <CheckBox IsChecked="{Binding IsSelected}" Click="GroupCheckBox_OnClick" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Label}"
                               Foreground="#B8C7D8"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                  </StackPanel>

                  <ItemsControl ItemsSource="{Binding Clips}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding $parent[Window].DataContext.CardWidth}"
                                Margin="4,4,20,24"
                                Background="#24303A"
                                CornerRadius="12"
                                BoxShadow="0 6 18 -6 #66000000"
                                IsVisible="{Binding IsMatchedByGameFilter}"
                                PointerPressed="ClipCard_OnPointerPressed"
                                PointerEntered="ClipCard_OnPointerEntered"
                                PointerExited="ClipCard_OnPointerExited">
                          <Border.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Export" Click="ClipContextExport_OnClick" />
                              <MenuItem Header="Open" Click="ClipContextOpen_OnClick" />
                              <MenuItem Header="Rename" Click="ClipContextRename_OnClick" />
                              <MenuItem Header="Open file location" Click="ClipContextOpenLocation_OnClick" />
                              <Separator />
                              <MenuItem Header="Delete" Click="ClipContextDelete_OnClick" Foreground="#D85E61" />
                            </ContextMenu>
                          </Border.ContextMenu>
                          <Border CornerRadius="12" ClipToBounds="True">
                          <Grid RowDefinitions="Auto,Auto">
                            <Border Grid.RowSpan="2"
                                    BorderBrush="{Binding SelectionBorderBrush}"
                                    BorderThickness="{Binding SelectionBorderThickness}"
                                    CornerRadius="12"
                                    IsVisible="{Binding IsCheckVisible}"
                                    IsHitTestVisible="False"
                                    ZIndex="10" />
                            <Border Background="#16202A" Height="{Binding $parent[Window].DataContext.CardImageHeight}">
                              <Grid>
                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                <Border Background="#661A2040" IsVisible="{Binding IsSelected}" IsHitTestVisible="False" />
                                <TextBlock Text="{Binding SelectionOrder}"
                                           IsVisible="{Binding HasSelectionOrder}"
                                           Foreground="#FFFFFF"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Opacity="0.9"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                  <TextBlock.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="10" OffsetX="0" OffsetY="0" Opacity="0.6" />
                                  </TextBlock.Effect>
                                </TextBlock>
                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,12,12,0"
                                        Padding="10,6"
                                        Background="#1A2530"
                                        CornerRadius="18">
                                  <StackPanel Orientation="Horizontal" Spacing="5">
                                    <PathIcon Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                              Width="12" Height="12"
                                              Foreground="#93A6B8"
                                              VerticalAlignment="Center"
                                              IsVisible="{Binding HasTrimEdit}" />
                                    <TextBlock Text="{Binding DurationLabel}" Foreground="#D8E2EE" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                                  </StackPanel>
                                </Border>
                                <CheckBox HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Margin="14"
                                          IsChecked="{Binding IsSelected}"
                                          IsVisible="{Binding IsCheckVisible}"
                                          Click="ClipCheckBox_OnClick" />
                              </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="#1E2A35">
                                <StackPanel Spacing="6" Margin="16,13,16,13">
                                <TextBlock Text="{Binding TileTopLabel}"
                                           Foreground="#8C98A7"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding TileTopLabel}"
                                           IsVisible="{Binding !IsMostRecentForGame}" />
                                <!-- Shows in place of the plain label above, only on
                                     each game's newest clip - filters the whole
                                     library to just that game when confirmed. -->
                                <Button Classes="gameFilterBadge" IsVisible="{Binding IsMostRecentForGame}">
                                  <Button.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                      <MenuItem Header="{Binding GameFilterMenuLabel}" Click="GameFilterMenuItem_OnClick" />
                                    </MenuFlyout>
                                  </Button.Flyout>
                                  <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TileTopLabel}"
                                               Foreground="#8C98A7"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis" />
                                    <PathIcon Data="M7,10L12,15L17,10Z" Width="10" Height="10" Foreground="#8C98A7" />
                                  </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding TileMainLabel}"
                                           Foreground="#EDF4FB"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <Path Data="M11.99,2C6.47,2,2,6.48,2,12s4.47,10,9.99,10C17.52,22,22,17.52,22,12S17.52,2,11.99,2z M12.5,7H11v6l5.25,3.15l0.75-1.23l-4.5-2.67V7z"
                                        Fill="#8C98A7" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                                  <TextBlock Text="{Binding RelativeDateLabel}"
                                             Foreground="#8C98A7"
                                             FontSize="12"
                                             FontWeight="SemiBold"
                                             VerticalAlignment="Center" />
                                  <TextBlock Text="{Binding CaptureBackendLabel}"
                                             Foreground="#5C6D7E"
                                             FontSize="11"
                                             IsVisible="{Binding HasCaptureBackendLabel}"
                                             TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" />
                                </StackPanel>
                                </StackPanel>
                            </Border>
                          </Grid>
                          </Border>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        </DockPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#101820" IsVisible="{Binding IsSettingsVisible}">
      <Grid ColumnDefinitions="240,*,Auto">
        <Border Grid.Column="0" Background="#0D1116" BorderBrush="#1E2A33" BorderThickness="0,0,1,0">
          <StackPanel Margin="16,24" Spacing="2">
            <TextBlock Text="GENERAL" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" Margin="14,0,0,14" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=General}" Tag="General" Content="General" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Game Detection}" Tag="Game Detection" Content="Game Detection" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Import from Medal}" Tag="Import from Medal" Content="Import from Medal" Click="SettingsNavButton_OnClick" />

            <TextBlock Text="CAPTURE" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" Margin="14,20,0,14" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Replay Buffer}" Tag="Replay Buffer" Content="Replay Buffer" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Overlays and Notifications}" Tag="Overlays and Notifications" Content="Overlays and Notifications" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Auto-Clip}" Tag="Auto-Clip" Content="Auto-Clipping" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Audio}" Tag="Audio" Content="Audio" Click="SettingsNavButton_OnClick" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Game Audio Exclusions}" Tag="Game Audio Exclusions" Content="Game Audio Exclusions" Click="SettingsNavButton_OnClick" />

            <TextBlock Text="ABOUT" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" Margin="14,20,0,14" />
            <Button Classes="settingsNavButton" Classes.active="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=About}" Tag="About" Content="About" Click="SettingsNavButton_OnClick" />
          </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" Classes="settingsScroll">
          <StackPanel Margin="36,28,36,40" Spacing="22">

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Replay Buffer}">
              <StackPanel Spacing="4">
                <TextBlock Text="REPLAY BUFFER" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Control how EVE records in the background and which capture backend it uses." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="6">
                  <TextBlock Text="Save hotkey" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <Button Content="{Binding HotkeyDisplay}" Click="HotkeyCaptureButton_OnClick" HorizontalAlignment="Left" MinWidth="200" />
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Replay length" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayDurationPresets}" SelectedItem="{Binding SelectedReplayDurationPreset}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Resolution" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayResolutions}" SelectedItem="{Binding SelectedReplayResolution}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Frame rate" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayFrameRates}" SelectedItem="{Binding SelectedReplayFrameRate}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding StringFormat={}{0} fps}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="Above 1080p60, Windows Capture clips take noticeably longer to process (the clip preview can sit black for a while before it loads)."
                               Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding ReplayQualityAboveDefault}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding ReplayQualityRestartRequired}">
                      <TextBlock Text="Restart the replay buffer for the resolution/frame rate change to take effect." Foreground="#E5A00D" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
                      <Button Content="Restart Buffer" Click="RestartReplayBufferButton_OnClick" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="6">
                  <TextBlock Text="Capture backend" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayBackends}" SelectedItem="{Binding SelectedReplayBackend}">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <TextBlock Text="{Binding SelectedReplayBackend.Description}" Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                  <TextBlock Text="Games with anti-cheat (EAC, BattlEye, Ricochet, etc.) often block OBS's game hook, causing a black or frozen capture. If a game doesn't record properly on OBS, switch to Auto (recommended)."
                             Foreground="#E5A00D" FontSize="12" FontWeight="Bold" TextWrapping="Wrap"
                             IsVisible="{Binding ReplayBackendIsObs}" />
                  <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding ReplayBackendRestartRequired}">
                    <TextBlock Text="Restart EVE for the backend change to take effect." Foreground="#E5A00D" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="Restart Now" Click="RestartAppButton_OnClick" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Full session recording" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="Also writes the entire session (video and audio) to EVE's VODs folder. EVE backend only for now." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding FullSessionRecordingEnabled}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Spacing="6" IsVisible="{Binding FullSessionRecordingEnabled}">
                    <TextBlock Text="Destination folder" Foreground="#B8C7D8" FontWeight="Bold" FontSize="13" />
                    <TextBlock Text="{Binding FullSessionRecordingFolderDisplay}" Foreground="#6B7C8C" FontSize="12" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="⚠ Finalizing a long session (muxing the whole thing) can take real time and heavy CPU/disk use, more so at higher quality/fps or longer sessions - other apps (Discord, Spotify, etc.) may stutter or freeze until it finishes."
                               Foreground="#E5A00D" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Overlays and Notifications}">
              <StackPanel Spacing="4">
                <TextBlock Text="OVERLAYS AND NOTIFICATIONS" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Turn the on-screen confirmation and sound on or off, and choose where and how loud it is when a clip saves." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Show clip saved overlay" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableClipOverlay}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Overlay position" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <ListBox Classes="pillGroup" ItemsSource="{Binding ClipOverlayPositions}" SelectedItem="{Binding SelectedClipOverlayPosition}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="52" Height="34" Background="#0D1116" BorderBrush="#2C3B48" BorderThickness="1" CornerRadius="4">
                              <Border Width="16" Height="8" Margin="4" CornerRadius="2" Background="#5864E8"
                                      HorizontalAlignment="{Binding Converter={x:Static opconv:OverlayPositionToHorizontalAlignmentConverter.Instance}}"
                                      VerticalAlignment="{Binding Converter={x:Static opconv:OverlayPositionToVerticalAlignmentConverter.Instance}}" />
                            </Border>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Play clip saved sound" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableClipOverlaySound}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Sound volume" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <ListBox Classes="pillGroup" ItemsSource="{Binding ClipOverlayVolumes}" SelectedItem="{Binding SelectedClipOverlayVolume}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="22" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=General}">
              <StackPanel Spacing="4">
                <TextBlock Text="GENERAL" Foreground="#5C6D7E" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="Startup behavior, layout, and clip filenames." Foreground="#93A6B8" FontSize="14" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <TextBlock Text="STARTUP" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Launch EVE on Windows boot" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                      <TextBlock Text="Starts EVE automatically when you sign in to Windows." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding LaunchOnWindowsStartup}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                  <Border Height="1" Background="#1B242D" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Start minimized on boot" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                      <TextBlock Text="Opens straight to the tray instead of showing the main window." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartMinimizedToTray}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <TextBlock Text="LAYOUT" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Show status panel" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                      <TextBlock Text="The right-hand panel here in Settings showing replay buffer status, hotkey, and active game." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsStatusAreaVisible}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Show &quot;Recording Paused&quot; indicator" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                      <TextBlock Text="Shows a badge over the video in Editor during moments the game window wasn't in focus while recording." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowRecordingPausedIndicator}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="12">
                  <TextBlock Text="CLIP FILENAMES" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <TextBlock Text="Choose how newly saved clips are named. Windows replaces unsupported filename characters such as colons with hyphens." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                  <ComboBox Classes="settingsInput" ItemsSource="{Binding ClipFileNameSchemes}" SelectedValue="{Binding SelectedClipFileNameScheme}" SelectedValueBinding="{Binding Value}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <StackPanel Spacing="6" IsVisible="{Binding IsCustomClipFileNameScheme}">
                    <TextBlock Foreground="#93A6B8" FontSize="12">Template: {title}, {game}, {datetime:format}</TextBlock>
                    <TextBox Classes="settingsInput" Text="{Binding CustomClipFileNameTemplate}" Watermark="{}{datetime:yyyy-MM-dd HH-mm-ss} - {title}" />
                    <TextBlock Text="{Binding ClipFileNameTemplateError}" Foreground="#E07070" FontSize="12" IsVisible="{Binding HasClipFileNameTemplateError}" TextWrapping="Wrap" />
                    <TextBlock Text="Date/time format help: Microsoft Learn" Tag="https://learn.microsoft.com/en-us/dotnet/standard/base-types/custom-date-and-time-format-strings" PointerPressed="LicenseLinkText_OnPointerPressed" Foreground="#75B8F0" FontSize="12" />
                  </StackPanel>
                  <TextBlock Text="Preview" Foreground="#93A6B8" FontSize="12" />
                  <Border Background="#1D2A36" BorderBrush="#2C3B48" BorderThickness="1" CornerRadius="7" Padding="14,10">
                    <TextBlock Text="{Binding ClipFileNamePreview}" Foreground="#D2DEEC" FontSize="13" TextWrapping="Wrap" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Apply the current scheme to every video in this library, including imports and Full Sessions stored here." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Rename all to updated scheme" Click="RenameAllClipsButton_OnClick" IsEnabled="{Binding CanRenameAllClips}" VerticalAlignment="Center" />
                  </Grid>
                  <TextBlock Text="{Binding RenameAllClipsStatus}" Foreground="#93A6B8" FontSize="12" TextWrapping="Wrap" IsVisible="{Binding HasRenameAllClipsStatus}" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Game Detection}">
              <StackPanel Spacing="4">
                <TextBlock Text="GAME DETECTION" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Add a game EVE doesn't recognize yet, and pick which capture backend any game should always use." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="16">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Add a running game" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                      <ComboBox Classes="settingsInput" ItemsSource="{Binding GameCandidateProcesses}" SelectedItem="{Binding SelectedGameProcess}" HorizontalAlignment="Stretch" />
                      <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                      <Button Grid.Column="2" Content="Add" Click="AddGameFromProcessButton_OnClick" />
                    </Grid>
                  </StackPanel>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Or browse for an executable" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                    <Button Content="Browse for game.exe" Click="BrowseCustomGameButton_OnClick" HorizontalAlignment="Left" />
                  </StackPanel>

                  <Border Height="1" Background="#1B242D" />

                  <TextBox Classes="settingsInput" Watermark="Search games" Text="{Binding GameSearchText}" />
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding GameCaptureRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" IsVisible="{Binding IsVisible}">
                      <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                          <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" />
                            <TextBlock Text="{Binding ExecutableName}" Foreground="#5C6D7E" FontSize="11" />
                          </StackPanel>
                          <ComboBox Grid.Column="1" Classes="settingsInput" Width="210" ItemsSource="{Binding $parent[Window].DataContext.ReplayBackends}" SelectedItem="{Binding SelectedBackend}" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Label}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <Button Grid.Column="2" Content="Remove" Width="80" IsVisible="{Binding IsCustom}" VerticalAlignment="Center" Click="RemoveCustomGameButton_OnClick" />
                        </Grid>
                        <TextBlock Text="⚠ Since this game has an anti-cheat, OBS may black out or freeze the capture (or get the game closed) - Auto, EVE or Windows Capture are safer."
                                   Foreground="#E5A00D" FontSize="11" FontWeight="Bold" TextWrapping="Wrap"
                                   IsVisible="{Binding ShowAntiCheatWarning}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Import from Medal}">
              <StackPanel Spacing="4">
                <TextBlock Text="IMPORT FROM MEDAL" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Finds clips Medal has recorded locally and copies (or moves) them into your EVE library, keeping Medal's own clip titles." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>
              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Strip emoji from titles" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding MedalImportStripEmoji}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                  <Border Height="1" Background="#1B242D" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Copy instead of move" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                      <TextBlock Text="On: Medal keeps its own copy. Off: clips are removed from Medal once imported." Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding MedalImportCopyNotMove}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="16">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                      <TextBlock Text="Scan for Medal clips" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="{Binding MedalScanStatusText}" Foreground="#93A6B8" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Scan for Medal Clips" Classes="primaryButton" Click="ScanMedalButton_OnClick" IsEnabled="{Binding !MedalImportInProgress}" VerticalAlignment="Center" />
                  </Grid>

                  <StackPanel IsVisible="{Binding MedalImportInProgress}" Spacing="6">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding MedalImportProgressPercent}" Height="8" />
                    <TextBlock Text="{Binding MedalImportStatusText}" Foreground="#6B7C8C" FontSize="12" />
                  </StackPanel>
                  <TextBlock Text="{Binding MedalImportStatusText}" Foreground="#6B7C8C" FontSize="12" IsVisible="{Binding ShowMedalImportStatusText}" />

                  <StackPanel Spacing="14" IsVisible="{Binding MedalScanned}">
                    <Border Height="1" Background="#1B242D" />

                    <Button Content="Import Selected" Click="ImportMedalButton_OnClick" HorizontalAlignment="Left" Classes="primaryButton"
                            IsEnabled="{Binding !MedalImportInProgress}" />

                    <ItemsControl ItemsSource="{Binding MedalImportRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#0F171E" BorderBrush="#1E2A33" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                              <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanImport}" VerticalAlignment="Center" />
                              <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayTitle}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" FontFamily="Segoe UI,Segoe UI Emoji" />
                                <TextBlock Foreground="#6B7C8C" FontSize="11">
                                  <Run Text="{Binding GameFolderName}" /><Run Text=" · " /><Run Text="{Binding CreatedAtLocal}" />
                                </TextBlock>
                                <TextBlock Text="{Binding ValidationMessage}" Foreground="#D85E61" FontSize="11" TextWrapping="Wrap" IsVisible="{Binding HasValidationMessage}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Auto-Clip}">
              <StackPanel Spacing="4">
                <TextBlock Text="AUTO-CLIPPING" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="EVE reads a game's own event feed to save a clip the instant one of these happens - no voice or screen analysis involved." Foreground="#93A6B8" TextWrapping="Wrap" />
                <TextBlock Text="⚠ Experimental - still being worked on and can miss events, mislabel clips, or misbehave." Foreground="#E5A00D" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0" />
              </StackPanel>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                  <Button Classes="autoClipCardHeader" Click="ToggleCs2CardButton_OnClick">
                    <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                      <Border Width="56" Height="56" CornerRadius="8" ClipToBounds="True">
                        <Image Source="/Assets/cs2-cover.jpg" Stretch="UniformToFill" />
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Counter-Strike 2" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                        <TextBlock Text="{Binding Cs2EventsSummary}" Foreground="#6B7C8C" FontSize="12" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Cs2CardExpanded, Converter={x:Static opconv:BoolToChevronConverter.Instance}}" Foreground="#93A6B8" FontSize="16" VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <StackPanel IsVisible="{Binding Cs2CardExpanded}" Margin="18,0,18,18" Spacing="12">
                    <Border Height="1" Background="#1B242D" />

                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Enable auto-clip for CS2" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Cs2AutoClipEnabled}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding Cs2GsiStatusText}" Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" IsVisible="{Binding Cs2AutoClipEnabled}" />

                    <Border Height="1" Background="#1B242D" />

                    <StackPanel>
                      <Button Classes="autoClipCardHeader" Click="ToggleCs2AllKillsButton_OnClick" Padding="0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                          <CheckBox IsChecked="{Binding Cs2AllKills}" IsHitTestVisible="False" />
                          <TextBlock Grid.Column="1" Text="All Kills" Foreground="#D2DEEC" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding Cs2AllKillsExpanded, Converter={x:Static opconv:BoolToChevronConverter.Instance}}" Foreground="#6B7C8C" FontSize="13" VerticalAlignment="Center" />
                        </Grid>
                      </Button>
                      <StackPanel Margin="26,8,0,0" Spacing="8" IsVisible="{Binding Cs2AllKillsExpanded}">
                        <CheckBox Content="Kill" IsChecked="{Binding Cs2Kill}" />
                        <CheckBox Content="2K" IsChecked="{Binding Cs2TwoKill}" />
                        <CheckBox Content="3K" IsChecked="{Binding Cs2ThreeKill}" />
                        <CheckBox Content="4K" IsChecked="{Binding Cs2FourKill}" />
                        <CheckBox Content="Ace" IsChecked="{Binding Cs2Ace}" />
                      </StackPanel>
                    </StackPanel>

                    <CheckBox Content="Headshot" IsChecked="{Binding Cs2Headshot}" />
                    <CheckBox Content="Death" IsChecked="{Binding Cs2Death}" />
                    <CheckBox Content="Assist" IsChecked="{Binding Cs2Assist}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Audio}">
              <StackPanel Spacing="4">
                <TextBlock Text="AUDIO" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Choose which app's audio gets tagged as Chat Audio and which microphone is recorded." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="18">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Chat Audio App" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Multiple apps" Foreground="#8C98A7" FontSize="12" VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding MultiChatAppEnabled}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                      </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6" IsVisible="{Binding !MultiChatAppEnabled}">
                      <TextBlock Text="Pick the app whose audio should be tagged Chat Audio in clips." Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedChatProcess}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding MultiChatAppEnabled}">
                      <TextBlock Text="Each app added here gets its own Chat Audio track in saved clips." Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedChatProcess}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                        <Button Grid.Column="2" Content="Add" Click="AddSelectedChatProcessButton_OnClick" />
                      </Grid>
                      <ItemsControl ItemsSource="{Binding ChatAudioApps}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="settingsCard" Padding="14,10" Margin="0,8,0,0">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding}" Foreground="#D8E4F2" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Remove" Click="RemoveChatAudioAppButton_OnClick" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </StackPanel>

                  <Border Height="1" Background="#1B242D" />

                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Microphone" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Multiple mics" Foreground="#8C98A7" FontSize="12" VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding MultiMicrophoneEnabled}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                      </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6" IsVisible="{Binding !MultiMicrophoneEnabled}">
                      <ComboBox Classes="settingsInput" ItemsSource="{Binding MicrophoneDevices}" SelectedItem="{Binding SelectedMicrophoneDevice}" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding MultiMicrophoneEnabled}">
                      <TextBlock Text="Each microphone added here gets its own track in saved clips." Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <ComboBox Classes="settingsInput" ItemsSource="{Binding MicrophoneDevices}" SelectedItem="{Binding SelectedMicrophoneDevice}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Add" Click="AddSelectedMicrophoneButton_OnClick" />
                      </Grid>
                      <ItemsControl ItemsSource="{Binding SelectedMicrophones}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="settingsCard" Padding="14,10" Margin="0,8,0,0">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding Name}" Foreground="#D8E4F2" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Remove" Click="RemoveMicrophoneButton_OnClick" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="16">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Microphone noise suppression" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="Reduces background noise (fans, keyboard, hum) on the mic track using ffmpeg's denoiser. Applied when a clip is saved." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding MicrophoneNoiseSuppressionEnabled}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                  </Grid>

                  <StackPanel Spacing="6" IsVisible="{Binding MicrophoneNoiseSuppressionEnabled}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Strength" Foreground="#B8C7D8" FontWeight="Bold" FontSize="13" />
                      <TextBlock Grid.Column="1" Text="{Binding MicrophoneNoiseSuppressionStrength, StringFormat={}{0:0} dB}" Foreground="#8C98A7" FontSize="12" />
                    </Grid>
                    <Slider Minimum="0" Maximum="30" Value="{Binding MicrophoneNoiseSuppressionStrength}" TickFrequency="1" IsSnapToTickEnabled="True" />
                    <TextBlock Text="Higher cuts more noise but can start eating into your voice past ~20." Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="settingsCard">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Audio sync offset" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                    <TextBlock Grid.Column="1" Text="{Binding AudioSyncOffsetMs, StringFormat={}{0:0} ms}" Foreground="#8C98A7" FontSize="12" />
                  </Grid>
                  <TextBlock Text="Exact audio/video latency varies by hardware. If audio sounds delayed in your saved clips, raise this; if audio sounds ahead, lower it." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                  <Slider Minimum="-500" Maximum="500" Value="{Binding AudioSyncOffsetMs}" TickFrequency="10" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Game Audio Exclusions}">
              <StackPanel Spacing="4">
                <TextBlock Text="GAME AUDIO EXCLUSIONS" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Apps here are removed from Game Audio. Chat Audio captures the selected app above." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>

              <Border Classes="settingsCard">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedProcessExclusion}" HorizontalAlignment="Stretch" />
                    <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                    <Button Grid.Column="2" Content="Add" Click="AddSelectedProcessButton_OnClick" />
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBox Name="ExcludedProcessTextBox" Classes="settingsInput" Watermark="discord.exe" />
                    <Button Grid.Column="1" Content="Add Manual" Click="AddExcludedProcessButton_OnClick" />
                  </Grid>
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding ExcludedProcesses}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="settingsCard" Padding="14,10" Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding}" Foreground="#D8E4F2" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Remove" Click="RemoveExcludedProcessButton_OnClick" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding SelectedSettingsSection, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=About}">
              <StackPanel Spacing="4">
                <TextBlock Text="ABOUT" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" />
                <TextBlock Text="Version, updates, source, and open source licenses." Foreground="#93A6B8" TextWrapping="Wrap" />
              </StackPanel>
              <Border Height="1" Background="#1B242D" />

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="20">
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <Border Width="52" Height="52" CornerRadius="12" Background="#1D2A36">
                    <Image Source="/Assets/eve-icon-24.png" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="EVE" Foreground="#EDF4FB" FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="A clip recorder and editor, made to be fast and to stay out of your way." Foreground="#8EA1B6" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding AppVersionDisplay}" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" Margin="0,4,0,0" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel Spacing="16">
                  <TextBlock Text="UPDATES" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Check for updates" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="EVE also checks automatically on launch." Foreground="#6B7C8C" FontSize="12" />
                    </StackPanel>
                    <Button Name="CheckNowButton" Grid.Column="1" Content="Check Now" Classes="primaryButton" Click="CheckUpdatesButton_OnClick" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel Spacing="16">
                  <TextBlock Text="SOURCE AND LICENSES" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="View on GitHub" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="Source code, releases, and issue tracker." Foreground="#6B7C8C" FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open GitHub" Click="OpenGitHubButton_OnClick" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel Spacing="16">
                  <TextBlock Text="DIAGNOSTICS" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Log folder" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                      <TextBlock Text="Open EVE's log files for troubleshooting a crash or capture issue." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open Logs" Click="OpenLogsButton_OnClick" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel Spacing="16">
                  <TextBlock Text="GET STARTED" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Setup walkthrough" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="Replay the first-time setup guide for library, capture, hotkey, and audio settings." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Show Walkthrough" Click="ShowWalkthroughButton_OnClick" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Background="#141D24" BorderBrush="#232F3A" BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel Spacing="10">
                  <TextBlock Text="LICENSES" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" Margin="0,0,0,4" />

                  <ItemsControl ItemsSource="{Binding ThirdPartyLicenseEntries}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="10" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <WrapPanel>
                          <TextBlock Text="This software uses libraries from the " Foreground="#8EA1B6" FontSize="13" />
                          <TextBlock Text="{Binding ProjectName}" Foreground="#BDD4EE" TextDecorations="Underline" FontSize="13" Cursor="Hand" Tag="{Binding ProjectUrl}" PointerPressed="LicenseLinkText_OnPointerPressed" />
                          <TextBlock Text=" project under the " Foreground="#8EA1B6" FontSize="13" />
                          <TextBlock Text="{Binding LicenseName}" Foreground="#BDD4EE" TextDecorations="Underline" FontSize="13" Cursor="Hand" Tag="{Binding LicenseUrl}" PointerPressed="LicenseLinkText_OnPointerPressed" />
                          <TextBlock Text="." Foreground="#8EA1B6" FontSize="13" />
                        </WrapPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Height="1" Background="#1B242D" Margin="0,4,0,0" />
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Full license text" Foreground="#D2DEEC" FontWeight="Bold" FontSize="15" />
                      <TextBlock Text="Complete notices and source links for every bundled component." Foreground="#6B7C8C" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="View Licenses" Click="OpenLicensesButton_OnClick" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2" Width="280" Background="#0D1116" BorderBrush="#1E2A33" BorderThickness="1,0,0,0" IsVisible="{Binding IsStatusAreaVisible}">
          <ScrollViewer>
            <StackPanel Margin="22,28,22,20">
              <TextBlock Text="STATUS" Foreground="#5C6D7E" FontSize="12" FontWeight="Bold" Margin="0,0,0,4" />
              <Border Height="1" Background="#1B242D" Margin="0,10,0,14" />

              <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Replay buffer" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="{Binding RecorderStatus}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="16" />
              </StackPanel>

              <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Save hotkey" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="{Binding HotkeyDisplay}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="16" />
              </StackPanel>

              <Border Height="1" Background="#1B242D" Margin="0,0,0,16" />

              <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Replay length" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReplayDurationPreset.Label}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="16" />
              </StackPanel>

              <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Resolution / FPS" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Foreground="#D2DEEC" FontWeight="Bold" FontSize="16">
                  <Run Text="{Binding SelectedReplayResolution.Label}" /><Run Text=" @ " /><Run Text="{Binding SelectedReplayFrameRate}" /><Run Text="fps" />
                </TextBlock>
              </StackPanel>

              <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Capture backend" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReplayBackend.Label}" Foreground="#D2DEEC" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
              </StackPanel>

              <Border Height="1" Background="#1B242D" Margin="0,0,0,16" />

              <StackPanel Spacing="2">
                <TextBlock Text="Library folder" Foreground="#5C6D7E" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="{Binding LibraryLocationText}" Foreground="#93A6B8" FontSize="12" TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" RowDefinitions="*,320" IsVisible="{Binding IsEditorVisible}">
      <Grid Background="#0E141A" ColumnDefinitions="*,300">
        <Border Background="#05080B">
          <Grid>
            <vlc:VideoView x:Name="EditorVideoView" IsVisible="{Binding !IsEditorVideoLoading}" />
            <!-- Two full ellipses, not partial-arc icon glyphs - an Ellipse's
                 layout bounding box is always exactly centered on the shape
                 regardless of how much of its stroke is actually drawn via
                 StrokeDashArray, so RenderTransformOrigin="0.5,0.5" rotates
                 each one cleanly in place around its own center. A
                 hand-drawn arc/icon's bounding box is NOT centered on the
                 circle it depicts (the missing wedge shifts it), which is
                 what made an earlier icon-based version of this wobble. -->
            <Grid IsVisible="{Binding IsEditorVideoLoading}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False">
              <Ellipse Width="40"
                       Height="40"
                       Stroke="#5C6D7E"
                       StrokeThickness="4"
                       StrokeDashArray="14,14"
                       StrokeLineCap="Round"
                       RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                  <RotateTransform />
                </Ellipse.RenderTransform>
                <Ellipse.Styles>
                  <Style Selector="Ellipse">
                    <Style.Animations>
                      <Animation Duration="0:0:1.4" IterationCount="INFINITE" Easing="LinearEasing">
                        <KeyFrame Cue="0%">
                          <Setter Property="RotateTransform.Angle" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                          <Setter Property="RotateTransform.Angle" Value="-360" />
                        </KeyFrame>
                      </Animation>
                    </Style.Animations>
                  </Style>
                </Ellipse.Styles>
              </Ellipse>
              <Ellipse Width="22"
                       Height="22"
                       Stroke="#93A6B8"
                       StrokeThickness="3"
                       StrokeDashArray="9,9"
                       StrokeLineCap="Round"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                  <RotateTransform />
                </Ellipse.RenderTransform>
                <Ellipse.Styles>
                  <Style Selector="Ellipse">
                    <Style.Animations>
                      <Animation Duration="0:0:0.9" IterationCount="INFINITE" Easing="LinearEasing">
                        <KeyFrame Cue="0%">
                          <Setter Property="RotateTransform.Angle" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                          <Setter Property="RotateTransform.Angle" Value="360" />
                        </KeyFrame>
                      </Animation>
                    </Style.Animations>
                  </Style>
                </Ellipse.Styles>
              </Ellipse>
            </Grid>
          </Grid>
        </Border>
        <Border Grid.Column="1" Background="#101820" BorderBrush="#1F2B34" BorderThickness="1,0,0,0">
          <StackPanel Margin="20" Spacing="14">
            <TextBlock Text="CLIP DETAILS" Foreground="#C4D9F2" FontSize="13" FontWeight="Bold" />
            <TextBlock Text="Title" Foreground="#93A6B8" FontSize="12" />
            <TextBox Text="{Binding EditorTitle}" Foreground="#EDF4FB" FontSize="14" FontWeight="Bold" Background="#0D151C" BorderBrush="#17232D" />
            <TextBlock Text="Description" Foreground="#93A6B8" FontSize="12" />
            <TextBox Text="{Binding EditorDescription}"
                     MinHeight="86"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Watermark="Type description here"
                     Background="#0D151C"
                     BorderBrush="#17232D"
                     Foreground="#D6E2F0" />
            <Border Height="1" Background="#22303A" Margin="0,10,0,0" />
            <TextBlock Text="Export codec" Foreground="#93A6B8" FontSize="12" />
            <ComboBox Classes="settingsInput"
                      ItemsSource="{Binding ExportCodecs}"
                      SelectedItem="{Binding SelectedExportCodec}"
                      Width="180"
                      HorizontalAlignment="Left" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Background="#141D24" BorderBrush="#22303A" BorderThickness="0,1,0,0">
        <Grid RowDefinitions="44,*" Margin="8,0,8,8">
          <Grid ColumnDefinitions="160,*,Auto" Height="44">
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
              <Button Classes="transportButton" Click="RestartButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 5,3 L 7,3 L 7,17 L 5,17 Z M 17,4 L 17,16 L 8,10 Z" />
              </Button>
              <Button Classes="transportButton" Click="StepBackButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 15,4 L 15,16 L 6,10 Z" />
              </Button>
              <Button Classes="playButton" Click="PlayPauseButton_OnClick">
                <Grid>
                  <PathIcon Width="16" Height="16" Foreground="#DDE8F6" Data="M 7,4 L 17,10 L 7,16 Z" IsVisible="{Binding !IsPlaying}" />
                  <PathIcon Width="16" Height="16" Foreground="#DDE8F6" Data="M 6,4 L 9,4 L 9,16 L 6,16 Z M 12,4 L 15,4 L 15,16 L 12,16 Z" IsVisible="{Binding IsPlaying}" />
                </Grid>
              </Button>
              <Button Classes="transportButton" Click="StepForwardButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 5,4 L 14,10 L 5,16 Z" />
              </Button>
              <Button Classes="transportButton" Click="EndButton_OnClick">
                <PathIcon Width="16" Height="16" Foreground="#C8D6E6" Data="M 15,3 L 17,3 L 17,17 L 15,17 Z M 4,4 L 13,10 L 4,16 Z" />
              </Button>
            </StackPanel>
            <Button Name="ExportButton"
                    Grid.Column="2"
                    Content="{Binding ExportButtonText}"
                    Classes="primaryButton"
                    Width="150"
                    Height="34"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding !IsExporting}"
                    Click="ExportButton_OnClick" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="160,*" ColumnSpacing="12">
            <Grid RowDefinitions="24,*">
              <TextBlock Text="{Binding TimelineStatusLabel}"
                         Foreground="#A8CFFF"
                         FontSize="11"
                         VerticalAlignment="Bottom"
                         FontFamily="Consolas" />
              <ItemsControl Grid.Row="1" ItemsSource="{Binding TimelineTracks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Height="{Binding LaneHeight}"
                            Margin="0,0,0,6"
                            Background="#141D24"
                            BorderBrush="#232F3A"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="False">
                      <Grid Margin="8,5" RowDefinitions="Auto,36" ColumnDefinitions="18,*,18">
                        <TextBlock Grid.ColumnSpan="3"
                                   Text="{Binding Label}"
                                   Foreground="#D4E0EA"
                                   FontSize="11"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Row="1"
                                Classes="trackMuteToggle"
                                Width="22"
                                Height="22"
                                CornerRadius="11"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsAudio}"
                                PointerPressed="TrackMuteToggle_OnPointerPressed"
                                Cursor="Hand"
                                ToolTip.Tip="Mute/unmute this track">
                          <PathIcon Width="14"
                                    Height="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding IsMuted, Converter={x:Static opconv:BoolToMuteBrushConverter.Instance}}"
                                    Data="{Binding IsMuted, Converter={x:Static opconv:BoolToMuteIconConverter.Instance}}" />
                        </Border>
                        <Slider Grid.Row="1"
                                Grid.Column="1"
                                Classes="volumeSlider"
                                Minimum="0"
                                Maximum="150"
                                Height="36"
                                MinHeight="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Margin="0,-10,0,0"
                                Value="{Binding VolumePercent, Mode=TwoWay}"
                                IsEnabled="{Binding CanAdjustVolume}"
                                IsVisible="{Binding IsAudio}"
                                Opacity="{Binding IsMuted, Converter={x:Static opconv:BoolToOpacityConverter.Instance}}"
                                PointerPressed="TrackVolume_OnPointerPressed"
                                PointerMoved="TrackVolume_OnPointerMoved"
                                PointerReleased="TrackVolume_OnPointerReleased"
                                PropertyChanged="TrackVolume_OnPropertyChanged" />
                        <PathIcon Grid.Row="1"
                                  Grid.Column="2"
                                  Width="14"
                                  Height="14"
                                  Foreground="#9FB2C5"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"
                                  IsVisible="{Binding IsAudio}" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#E8EEF8"
                                CornerRadius="4"
                                Padding="5,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{Binding VolumeBadgeMargin}"
                                ZIndex="10"
                                IsHitTestVisible="False"
                                IsVisible="{Binding ShowVolumePercent}">
                          <TextBlock Text="{Binding VolumeLabel}" Foreground="#18202A" FontSize="10" FontWeight="Bold" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="24,*">
              <controls:TimelineRulerControl x:Name="TimelineRuler"
                                             Duration="{Binding Duration}"
                                             PointerPressed="TimelineSurface_OnPointerPressed"
                                             PointerMoved="TimelineSurface_OnPointerMoved"
                                             PointerReleased="TimelineSurface_OnPointerReleased" />
              <Grid x:Name="TimelineSurface"
                    Grid.Row="1"
                    SizeChanged="TimelineSurface_OnSizeChanged"
                    PointerPressed="TimelineSurface_OnPointerPressed"
                    PointerMoved="TimelineSurface_OnPointerMoved"
                    PointerReleased="TimelineSurface_OnPointerReleased">
                <ItemsControl ItemsSource="{Binding TimelineTracks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:TimelineLaneControl Height="{Binding LaneHeight}"
                                                    Margin="0,0,0,6"
                                                    LaneBrush="{Binding Color}"
                                                    IsVideo="{Binding IsVideo}"
                                                    Peaks="{Binding WaveformPeaks}"
                                                    TrimStartPercent="{Binding $parent[Window].DataContext.TrimStartPercentValue}"
                                                    TrimEndPercent="{Binding $parent[Window].DataContext.TrimEndPercentValue}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Canvas x:Name="TimelineOverlay" IsHitTestVisible="False">
                  <Border x:Name="TrimSelection"
                          Height="32"
                          BorderBrush="#13C8B5"
                          BorderThickness="2"
                          CornerRadius="4"
                          Background="#151F24" />
                  <Border x:Name="TimelinePlayhead"
                          Width="3"
                          Background="#F2F6FB" />
                  <Polygon x:Name="PlayheadCap"
                           Points="0,0 16,0 8,10"
                           Fill="#F2F6FB" />
                </Canvas>

                <Canvas x:Name="TimelineHandleLayer">
                  <Border x:Name="TrimStartHandle"
                          Width="14"
                          Height="32"
                          Background="#13C8B5"
                          CornerRadius="2"
                          Cursor="SizeWestEast"
                          PointerPressed="TrimStartHandle_OnPointerPressed"
                          PointerMoved="TimelineSurface_OnPointerMoved"
                          PointerReleased="TimelineSurface_OnPointerReleased" />
                  <Border x:Name="TrimEndHandle"
                          Width="14"
                          Height="32"
                          Background="#13C8B5"
                          CornerRadius="2"
                          Cursor="SizeWestEast"
                          PointerPressed="TrimEndHandle_OnPointerPressed"
                          PointerMoved="TimelineSurface_OnPointerMoved"
                          PointerReleased="TimelineSurface_OnPointerReleased" />
                </Canvas>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.RowSpan="2" Background="#000000AA" IsVisible="{Binding IsOnboardingVisible}">
      <Border Width="560" MaxHeight="640" CornerRadius="12" Background="#111920" BorderBrush="#232F3A" BorderThickness="1"
              HorizontalAlignment="Center" VerticalAlignment="Center">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Height="40" Background="#0C1319">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center">
              <Image Source="/Assets/eve-icon-24.png" Width="16" Height="16" />
              <TextBlock Text="Welcome to EVE" Foreground="#B9C6D4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="2" Classes="dialogClose" Content="✕" Width="40" Height="40" Click="OnboardingSkipButton_OnClick" />
          </Grid>

          <StackPanel DockPanel.Dock="Bottom" Margin="22,0,22,20" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
              <Border Width="8" Height="8" CornerRadius="4" Background="{Binding OnboardingStep, Converter={x:Static opconv:OnboardingDotBrushConverter.Instance}, ConverterParameter=Replay Buffer}" />
              <Border Width="8" Height="8" CornerRadius="4" Background="{Binding OnboardingStep, Converter={x:Static opconv:OnboardingDotBrushConverter.Instance}, ConverterParameter=Capture Backend}" />
              <Border Width="8" Height="8" CornerRadius="4" Background="{Binding OnboardingStep, Converter={x:Static opconv:OnboardingDotBrushConverter.Instance}, ConverterParameter=Startup}" />
              <Border Width="8" Height="8" CornerRadius="4" Background="{Binding OnboardingStep, Converter={x:Static opconv:OnboardingDotBrushConverter.Instance}, ConverterParameter=Audio}" />
              <Border Width="8" Height="8" CornerRadius="4" Background="{Binding OnboardingStep, Converter={x:Static opconv:OnboardingDotBrushConverter.Instance}, ConverterParameter=Game Audio Exclusions}" />
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Button Content="Skip" Classes="linkButton" VerticalAlignment="Center" Click="OnboardingSkipButton_OnClick" />
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <Button Content="Back" Width="96" HorizontalContentAlignment="Center" IsEnabled="{Binding OnboardingBackEnabled}" Click="OnboardingBackButton_OnClick" />
                <Button Content="{Binding OnboardingNextLabel}" Width="96" HorizontalContentAlignment="Center" Classes="primaryButton" Click="OnboardingNextButton_OnClick" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <ScrollViewer>
            <StackPanel Margin="22,20,22,18" Spacing="16">
              <TextBlock Text="{Binding OnboardingStepNumber, StringFormat='STEP {0} OF 5'}" Foreground="#6B7C8C" FontSize="12" FontWeight="Bold" />

              <StackPanel Spacing="16" IsVisible="{Binding OnboardingStep, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Replay Buffer}">
                <TextBlock Text="Library and replay buffer" Foreground="#EDF4FB" FontWeight="Bold" FontSize="18" />
                <TextBlock Text="Pick where clips save, your save hotkey, and how long the replay buffer holds." Foreground="#B9C6D4" FontSize="13" TextWrapping="Wrap" />

                <StackPanel Spacing="6">
                  <TextBlock Text="Library folder" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding LibraryFolderDisplay}" Foreground="#6B7C8C" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1" Content="Use Default" Click="ResetLibraryFolderButton_OnClick" />
                    <Button Grid.Column="2" Content="Change Folder" Click="FolderButton_OnClick" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Text="Save hotkey" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <Button Content="{Binding HotkeyDisplay}" Click="HotkeyCaptureButton_OnClick" HorizontalAlignment="Left" MinWidth="200" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Text="Replay length" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayDurationPresets}" SelectedItem="{Binding SelectedReplayDurationPreset}">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="16" IsVisible="{Binding OnboardingStep, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Capture Backend}">
                <TextBlock Text="Capture backend" Foreground="#EDF4FB" FontWeight="Bold" FontSize="18" />
                <TextBlock Text="&quot;Auto&quot; (recommended) uses EVE's own capture engine for every game - no process hook, so it's safe for anti-cheat too. Per-game overrides live in Settings &gt; Game Detection if you need one later." Foreground="#B9C6D4" FontSize="13" TextWrapping="Wrap" />
                <ListBox Classes="pillGroup" ItemsSource="{Binding ReplayBackends}" SelectedItem="{Binding SelectedReplayBackend}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{Binding SelectedReplayBackend.Description}" Foreground="#6B7C8C" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Spacing="16" IsVisible="{Binding OnboardingStep, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Startup}">
                <TextBlock Text="Startup behavior" Foreground="#EDF4FB" FontWeight="Bold" FontSize="18" />
                <TextBlock Text="How EVE behaves when it launches." Foreground="#B9C6D4" FontSize="13" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Launch EVE on Windows boot" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                  <ToggleSwitch Grid.Column="1" IsChecked="{Binding LaunchOnWindowsStartup}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Start minimized to tray" Foreground="#D2DEEC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                  <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartMinimizedToTray}" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="16" IsVisible="{Binding OnboardingStep, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Audio}">
                <TextBlock Text="Chat Audio and microphone" Foreground="#EDF4FB" FontWeight="Bold" FontSize="18" />
                <TextBlock Text="Pick the app whose audio should be tagged Chat Audio in clips, and which microphone gets recorded." Foreground="#B9C6D4" FontSize="13" TextWrapping="Wrap" />

                <StackPanel Spacing="6">
                  <TextBlock Text="Chat Audio App" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedChatProcess}" HorizontalAlignment="Stretch" />
                    <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                  </Grid>
                  <TextBlock Text="Multiple chat apps? Turn that on later in Settings &gt; Audio." Foreground="#6B7C8C" FontSize="11" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Text="Microphone" Foreground="#B8C7D8" FontWeight="Bold" FontSize="15" />
                  <ComboBox Classes="settingsInput" ItemsSource="{Binding MicrophoneDevices}" SelectedItem="{Binding SelectedMicrophoneDevice}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="Multiple microphones? Turn that on later in Settings &gt; Audio." Foreground="#6B7C8C" FontSize="11" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="16" IsVisible="{Binding OnboardingStep, Converter={x:Static conv:ObjectConverters.Equal}, ConverterParameter=Game Audio Exclusions}">
                <TextBlock Text="Game Audio exclusions" Foreground="#EDF4FB" FontWeight="Bold" FontSize="18" />
                <TextBlock Text="Whatever app is picked as Chat Audio is already removed from Game Audio. Add anything else here (music players, notification sounds) you don't want counted as game audio." Foreground="#B9C6D4" FontSize="13" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <ComboBox Classes="settingsInput" ItemsSource="{Binding OpenProcesses}" SelectedItem="{Binding SelectedProcessExclusion}" HorizontalAlignment="Stretch" />
                  <Button Grid.Column="1" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
                  <Button Grid.Column="2" Content="Add" Click="AddSelectedProcessButton_OnClick" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <TextBox Name="OnboardingExcludedProcessTextBox" Classes="settingsInput" Watermark="discord.exe" />
                  <Button Grid.Column="1" Content="Add Manual" Click="AddExcludedProcessOnboardingButton_OnClick" />
                </Grid>
                <ItemsControl ItemsSource="{Binding ExcludedProcesses}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Text="{Binding}" Foreground="#D8E4F2" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Remove" Click="RemoveExcludedProcessButton_OnClick" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Border>
  </Grid>
</Window>

